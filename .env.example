# Outdoor Gear Shop Medusa environment templates
# Copy these values into the app-specific env files:
# - apps/backend/.env
# - apps/storefront/.env.local

# Backend
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://paperclip-hth-outdoor-gear-shop-admin.hqkj.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://paperclip-hth-outdoor-gear-shop-admin.hqkj.com
__MEDUSA_ADMIN_ADDITIONAL_ALLOWED_HOSTS=paperclip-hth-outdoor-gear-shop-admin.hqkj.com
REDIS_URL=redis://localhost:16379
JWT_SECRET=change_me_to_a_long_random_value
COOKIE_SECRET=change_me_to_a_long_random_value
DATABASE_URL=postgres://postgres:postgres@localhost:15432/outdoor_gear_shop?sslmode=disable
DB_NAME=outdoor_gear_shop

# Storefront
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=replace_after_backend_seed
NEXT_PUBLIC_DEFAULT_REGION=us
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPPORT_EMAIL=preview@example.com
PREVIEW_ANALYTICS_DATABASE_URL=postgres://postgres:postgres@localhost:15432/outdoor_gear_shop?sslmode=disable
NEXT_PUBLIC_STRIPE_KEY=
NODE_ENV=development

# Docker Compose host port overrides
POSTGRES_DB=outdoor_gear_shop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=15432
REDIS_PORT=16379
BACKEND_PORT=9000
STOREFRONT_PORT=8000
