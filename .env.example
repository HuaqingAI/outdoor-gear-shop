# Shopify Admin API credentials
# Copy this file to .env (git-ignored) and fill in real values.
# Never commit .env or paste credentials into issue comments / chat.

SHOPIFY_STORE_DOMAIN=replace-with-shop.myshopify.com
SHOPIFY_CLIENT_ID=replace_with_real_client_id
SHOPIFY_CLIENT_SECRET=replace_with_real_client_secret

# Optional legacy fallback only if you already have a valid short-lived token.
# Shopify recommends exchanging client credentials for a token instead.
# SHOPIFY_ADMIN_API_TOKEN=shpat_REPLACE_WITH_REAL_TOKEN

# Required scopes for setup scripts:
#   read_products write_products
#   read_themes write_themes
#   read_metafields write_metafields
#   read_online_store_pages write_online_store_pages
#   read_content write_content
