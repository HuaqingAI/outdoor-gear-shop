{
  "name": "outdoor-gear-shop",
  "private": true,
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:seed": "turbo seed --filter=@outdoor-gear/backend",
    "preview:verify-catalog": "node scripts/verify-preview-catalog.mjs",
    "backend:dev": "turbo dev --filter=@outdoor-gear/backend",
    "storefront:dev": "turbo dev --filter=@outdoor-gear/storefront"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "turbo": "^2.0.14",
    "prettier": "^3.2.5"
  }
}
